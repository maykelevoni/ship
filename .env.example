# =============================================================================
# ENVIRONMENT VARIABLES — INFRA-LEVEL CONFIGURATION
# =============================================================================
#
# Keys in this file are infrastructure-level: database, auth, and AI bootstrap.
# Most API keys (PostBridge, Gemini, OpenRouter, Brevo, ElevenLabs, Ghost, etc.)
# are ALSO configurable via the Settings page UI and stored in the database.
# Keys defined here take precedence during initial setup, before the Settings
# page has been configured.
#
# Copy this file to .env.local and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# App - Don't add "/" in the end of the url (same in production)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js / Auth.js)
# -----------------------------------------------------------------------------
AUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_OAUTH_TOKEN=

# -----------------------------------------------------------------------------
# Database (PostgreSQL - Neon DB)
# -----------------------------------------------------------------------------
DATABASE_URL='postgres://[user]:[password]@[neon_hostname]/[dbname]?sslmode=require'

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
EMAIL_FROM="PostForge <noreply@yourdomain.com>"

# -----------------------------------------------------------------------------
# AI Content Generation (Anthropic Claude)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# AI Content Generation - OpenRouter (optional fallback AI provider)
# Get your key at https://openrouter.ai
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Image Generation (Google Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Social Posting (post-bridge)
# -----------------------------------------------------------------------------
POSTBRIDGE_API_KEY=

# -----------------------------------------------------------------------------
# Email Marketing (Brevo, formerly Sendinblue)
# Note: BREVO_SMTP_KEY is a separate credential from BREVO_API_KEY;
#       find it under Brevo > SMTP & API > SMTP tab.
# -----------------------------------------------------------------------------
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=PostForge
BREVO_TO_EMAIL=you@yourdomain.com
BREVO_SMTP_KEY=

# -----------------------------------------------------------------------------
# Text-to-Speech (ElevenLabs)
# ELEVENLABS_VOICE_ID defaults to "21m00Tcm4TlvDq8ikWAM" (Rachel) if not set.
# Find voice IDs at https://elevenlabs.io/voice-library
# -----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# -----------------------------------------------------------------------------
# Research - YouTube Data API v3
# Create a project and enable the YouTube Data API at https://console.cloud.google.com
# -----------------------------------------------------------------------------
YOUTUBE_API_KEY=

# -----------------------------------------------------------------------------
# Research - NewsAPI
# Get your key at https://newsapi.org
# -----------------------------------------------------------------------------
NEWSAPI_KEY=

# -----------------------------------------------------------------------------
# Publishing - Ghost CMS
# GHOST_URL should point to your Ghost instance, e.g. http://your-vps:2368
# GHOST_ADMIN_API_KEY is generated under Ghost Admin > Integrations > Add custom integration
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Ghost CMS (Docker)
# Ghost uses its own MySQL database. Access at http://localhost:2368/ghost
# -----------------------------------------------------------------------------
GHOST_URL=http://localhost:2368
GHOST_MYSQL_ROOT_PASSWORD=changeme
GHOST_MYSQL_DATABASE=ghost
GHOST_MYSQL_USER=ghost
GHOST_MYSQL_PASSWORD=changeme
GHOST_ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Image generation fallback (Replicate FLUX)
# -----------------------------------------------------------------------------
REPLICATE_API_KEY=

# -----------------------------------------------------------------------------
# Affiliate - Amazon PAAPI 5.0
# -----------------------------------------------------------------------------
AMAZON_PA_API_KEY=
AMAZON_PA_API_SECRET=
AMAZON_AFFILIATE_TAG=

# -----------------------------------------------------------------------------
# Affiliate - ClickBank Marketplace
# -----------------------------------------------------------------------------
CLICKBANK_API_KEY=
CLICKBANK_ACCOUNT=

# -----------------------------------------------------------------------------
# Payments - Stripe (optional, for payment webhooks)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Analytics - PostHog (optional)
# NEXT_PUBLIC_POSTHOG_HOST defaults to https://app.posthog.com if not set.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# -----------------------------------------------------------------------------
# Payments - Polar.sh (subscription billing)
# POLAR_WEBHOOK_SECRET: copy from Polar Dashboard > Webhooks > your endpoint
# POLAR_STARTER_PRODUCT_ID: product ID for the Starter plan
# POLAR_PRO_PRODUCT_ID: product ID for the Pro plan
# NEXT_PUBLIC_POLAR_CHECKOUT_URL: your Polar checkout link shown to users
# -----------------------------------------------------------------------------
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
NEXT_PUBLIC_POLAR_CHECKOUT_URL=
