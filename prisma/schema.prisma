// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")
  role          UserRole  @default(USER)

  accounts Account[]
  sessions Session[]

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Promotion {
  id             String         @id @default(cuid())
  type           String         // product | service | affiliate | lead_magnet | content
  name           String
  description    String
  url            String
  affiliateLink  String?
  price          String?
  benefits       String?        // JSON stringified array
  targetAudience String?
  status         String         @default("active") // active | paused | archived
  weight         Int            @default(5)
  geoScore       Int?
  geoIssues      String?        // JSON stringified array
  geoAuditedAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  contentPieces  ContentPiece[]
}

model ContentPiece {
  id           String     @id @default(cuid())
  promotionId  String?
  promotion    Promotion? @relation(fields: [promotionId], references: [id])
  blogPostId   String?
  blogPost     BlogPost?  @relation(fields: [blogPostId], references: [id])
  date         DateTime
  platform     String     // master | twitter | linkedin | reddit | instagram | email | image_card | image_quote | video
  content      String
  mediaPath    String?
  status       String     @default("queued") // queued | generating | generated | approved | posting | posted | failed | rejected
  approved     Boolean    @default(false)
  postBridgeId String?
  postedAt     DateTime?
  error        String?
  scheduledAt  DateTime?   // null = not scheduled; when set, worker posts at this time
  provider     String     @default("claude")  // "claude" | "gemini"
  templateId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ResearchTopic {
  id        String   @id @default(cuid())
  date      DateTime
  source    String   // "youtube" | "reddit" | "newsapi"
  title     String
  url       String?
  summary   String?
  score     Int      @default(5)
  rationale String?
  selected  Boolean  @default(false)
  createdAt DateTime @default(now())
  blogPosts BlogPost[]
}

model BlogPost {
  id             String         @id @default(cuid())
  date           DateTime
  topicId        String?
  topic          ResearchTopic? @relation(fields: [topicId], references: [id])
  title          String
  slug           String?
  seoDescription String?
  content        String         @db.Text
  ghostId        String?
  ghostUrl       String?
  status         String         @default("draft")
  contentPieces  ContentPiece[]
  emailDraft     EmailDraft?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model EmailDraft {
  id              String   @id @default(cuid())
  blogPostId      String   @unique
  blogPost        BlogPost @relation(fields: [blogPostId], references: [id])
  subject         String
  body            String   @db.Text
  suggestedPromos String?
  status          String   @default("pending")
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PromotionOpportunity {
  id          String   @id @default(cuid())
  date        DateTime
  type        String   // "affiliate" | "ghost_offer" | "digital_product" | "product_gap"
  title       String
  rationale   String
  searchQuery String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Template {
  id              String          @id @default(cuid())
  name            String
  platform        String          // twitter | linkedin | instagram | facebook | reddit | email | tiktok | youtube
  charLimit       Int?
  imageEnabled    Boolean         @default(false)
  imageWidth      Int?
  imageHeight     Int?
  videoEnabled    Boolean         @default(false)
  videoWidth      Int?
  videoHeight     Int?
  includeLink     Boolean         @default(false)
  aiInstructions  String?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]
}

model ScheduleEntry {
  id         String   @id @default(cuid())
  time       String   // "HH:MM" 24h
  platform   String
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  daysOfWeek String   @default("[0,1,2,3,4,5,6]")  // JSON int[] 0=Sun … 6=Sat
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EngineRun {
  id            String   @id @default(cuid())
  date          DateTime
  promotionId   String?
  promotionName String?
  status        String   // running | completed | failed
  log           String
  contentCount  Int      @default(0)
  createdAt     DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model OwnProduct {
  id            String   @id @default(cuid())
  opportunityId String?
  title         String
  description   String   @default("")
  outline       String   @db.Text
  status        String   @default("outline")
  platform      String?
  checkoutUrl   String?
  price         Float    @default(9.99)
  promotionId   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MediaAsset {
  id         String       @id @default(cuid())
  type       String       // 'image' | 'video'
  prompt     String       @db.Text
  groupId    String       // all platform resizes from same generation share this
  parentId   String?      // null = root; set = iterative variation
  parent     MediaAsset?  @relation("variations", fields: [parentId], references: [id])
  variations MediaAsset[] @relation("variations")
  platform   String?      // null = base | 'blog' | 'tiktok' | 'twitter'
  filePath   String?
  status     String       @default("pending") // pending | done | failed
  errorMsg   String?
  width      Int?
  height     Int?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}
