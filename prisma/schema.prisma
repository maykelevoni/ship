// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map(name: "created_at")
  updatedAt         DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now()) @map(name: "created_at")
  updatedAt     DateTime  @default(now()) @map(name: "updated_at")
  role          UserRole  @default(USER)

  accounts Account[]
  sessions Session[]

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map(name: "verification_tokens")
}

model Promotion {
  id             String         @id @default(cuid())
  type           String         // product | service | affiliate | lead_magnet | content
  name           String
  description    String
  url            String
  affiliateLink  String?
  price          String?
  benefits       String?        // JSON stringified array
  targetAudience String?
  status         String         @default("active") // active | paused | archived
  weight         Int            @default(5)
  geoScore       Int?
  geoIssues      String?        // JSON stringified array
  geoAuditedAt   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  contentPieces  ContentPiece[]
}

model ContentPiece {
  id           String    @id @default(cuid())
  promotionId  String
  promotion    Promotion @relation(fields: [promotionId], references: [id])
  date         DateTime
  platform     String    // master | twitter | linkedin | reddit | instagram | email | image_card | image_quote | video
  content      String
  mediaPath    String?
  status       String    @default("queued") // queued | generating | generated | approved | posting | posted | failed | rejected
  approved     Boolean   @default(false)
  postBridgeId String?
  postedAt     DateTime?
  error        String?
  provider     String    @default("claude")  // "claude" | "gemini"
  templateId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Template {
  id              String          @id @default(cuid())
  name            String
  platform        String          // twitter | linkedin | instagram | facebook | reddit | email | tiktok | youtube
  charLimit       Int?
  imageEnabled    Boolean         @default(false)
  imageWidth      Int?
  imageHeight     Int?
  videoEnabled    Boolean         @default(false)
  videoWidth      Int?
  videoHeight     Int?
  includeLink     Boolean         @default(false)
  aiInstructions  String?
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  scheduleEntries ScheduleEntry[]
}

model ScheduleEntry {
  id         String   @id @default(cuid())
  time       String   // "HH:MM" 24h
  platform   String
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  daysOfWeek String   @default("[0,1,2,3,4,5,6]")  // JSON int[] 0=Sun … 6=Sat
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EngineRun {
  id            String   @id @default(cuid())
  date          DateTime
  promotionId   String?
  promotionName String?
  status        String   // running | completed | failed
  log           String
  contentCount  Int      @default(0)
  createdAt     DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
